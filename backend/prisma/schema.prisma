// HotelSuite — Prisma schema
// Datasource: SQL Server (código agnóstico para migrar a PostgreSQL si hiciera falta).
// FASE 1: Auth, Roles y Multi-sucursal.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

/// Sucursal (tenant). Toda entidad operativa se relaciona con una Branch.
model Branch {
  id         String   @id @default(uuid())
  name       String
  address    String?
  taxId      String? // RUC / identificación fiscal
  legalName  String? // razón social
  phone      String?
  email      String?
  logoUrl    String?
  currency   String   @default("PEN")
  cutoffHour Int      @default(0) // hora de corte de turno (0-23)
  status     String   @default("active") // active | inactive
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  users          UserBranch[]
  roomTypes      RoomType[]
  roomAttributes RoomAttribute[]
  clientTiers    ClientTier[]
  rates          Rate[]
  customRates    CustomRate[]
  settings       Setting[]
  areas          Area[]
  inventoryCategories InventoryCategory[]
  items          Item[]
  schedules      Schedule[]
  rooms          Room[]
  stays          Stay[]
  reservations   Reservation[]
  observations   Observation[]
  conciergeRequests ConciergeRequest[]
  warehouses     Warehouse[]
  products       Product[]
  cashSessions   CashSession[]
  sales          Sale[]
  folioSeries    FolioSeries[]
  invoices       Invoice[]
  creditDebitNotes CreditDebitNote[]
  inventoryMovements InventoryMovement[]
  suppliers        Supplier[]
  purchaseInvoices PurchaseInvoice[]
  checklistItems   ChecklistItem[]
  housekeepingTasks HousekeepingTask[]
  maintenances     Maintenance[]
  revisions        Revision[]
  laundryMachines  LaundryMachine[]
  laundryTasks     LaundryTask[]
  biometricDevices BiometricDevice[]
  whatsappInstances WhatsAppInstance[]
  messageTemplates MessageTemplate[]
  messageLogs      MessageLog[]
  reminders        Reminder[]
  wifiCredentials  WifiCredential[]
  linenItems       LinenItem[]
  linenStocks      LinenStock[]
  linenMovements   LinenMovement[]
  cleaningShifts   CleaningShift[]
  roomSupplies     RoomSupply[]
  productRequests  ProductRequest[]
  stockWriteOffs   StockWriteOff[]
  printJobs        PrintJob[]
  roomTypeDotaciones     RoomTypeDotacion[]
  roomInventories        RoomInventory[]
  roomInventoryMovements RoomInventoryMovement[]
  linenLocationStocks    LinenLocationStock[]

  @@index([status])
}

/// Usuario del sistema. Pertenece a un rol y opera una o varias sucursales.
model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  phone        String? // teléfono de contacto (perfil)
  passwordHash String
  status       String   @default("active") // active | inactive
  roleId       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  role          Role           @relation(fields: [roleId], references: [id])
  branches      UserBranch[]
  refreshTokens RefreshToken[]

  @@index([roleId])
  @@index([status])
}

/// Rol con un conjunto de permisos (RBAC granular).
model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false) // roles protegidos (ej. Super Admin)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  permissions RolePermission[]
}

/// Catálogo de permisos: combinación módulo × acción.
model Permission {
  id          String   @id @default(uuid())
  module      String // dashboard | operations | finance | ...
  action      String // view | create | edit | delete | approve
  description String?
  createdAt   DateTime @default(now())

  roles RolePermission[]

  @@unique([module, action])
  @@index([module])
}

/// Tabla puente Role ↔ Permission.
model RolePermission {
  id           String @id @default(uuid())
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

/// Tabla puente User ↔ Branch (un usuario puede operar varias sucursales).
model UserBranch {
  id       String @id @default(uuid())
  userId   String
  branchId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([userId, branchId])
  @@index([userId])
  @@index([branchId])
}

/// Refresh tokens emitidos (hash), para rotación y logout/revocación real.
model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// FASE 2 — Catálogos (Tanda 2A)
// ─────────────────────────────────────────────────────────────────────────────

/// Configuración flexible clave/valor. branchId nulo = ajuste global.
model Setting {
  id        String   @id @default(uuid())
  branchId  String?
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch Branch? @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, key])
  @@index([branchId])
}

/// Tipo de habitación (por sucursal). Agrupa atributos y tarifas.
model RoomType {
  id          String   @id @default(uuid())
  branchId    String
  name        String
  description String?
  capacity    Int      @default(2)
  basePrice   Decimal? @db.Decimal(10, 2)
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  branch      Branch             @relation(fields: [branchId], references: [id], onDelete: Cascade)
  attributes  RoomTypeAttribute[]
  rates        Rate[]
  customRates  CustomRate[]
  rooms        Room[]
  reservations Reservation[]
  dotaciones   RoomTypeDotacion[]

  @@index([branchId])
  @@index([status])
}

/// Atributo de habitación (por sucursal): TV, A/C, jacuzzi, etc.
model RoomAttribute {
  id        String   @id @default(uuid())
  branchId  String
  name      String
  icon      String?
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch    Branch              @relation(fields: [branchId], references: [id], onDelete: Cascade)
  roomTypes RoomTypeAttribute[]

  @@index([branchId])
}

/// Tabla puente RoomType ↔ RoomAttribute.
model RoomTypeAttribute {
  id          String @id @default(uuid())
  roomTypeId  String
  attributeId String

  roomType  RoomType      @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  attribute RoomAttribute @relation(fields: [attributeId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([roomTypeId, attributeId])
  @@index([roomTypeId])
  @@index([attributeId])
}

/// Tier de cliente (por sucursal): aplica un descuento porcentual.
model ClientTier {
  id              String   @id @default(uuid())
  branchId        String
  name            String
  discountPercent Decimal  @default(0) @db.Decimal(5, 2)
  description     String?
  status          String   @default("active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  branch      Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  customRates CustomRate[]
  stays       Stay[]

  @@index([branchId])
}

/// Cliente / huésped. GLOBAL: compartido entre sucursales.
model Guest {
  id             String   @id @default(uuid())
  documentType   String   @default("DNI") // DNI | CE | PASAPORTE | RUC
  documentNumber String
  firstName      String
  lastName       String?
  phone          String?
  email          String?
  notes          String?
  status         String   @default("active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  stays           Stay[]
  additionalStays StayGuest[]
  reservations    Reservation[]

  @@unique([documentType, documentNumber])
  @@index([documentNumber])
}

/// Tarifa base por tipo de habitación y duración (en minutos).
model Rate {
  id              String   @id @default(uuid())
  branchId        String
  roomTypeId      String
  label           String // "3 horas", "12 horas", "Noche", etc.
  durationMinutes Int
  price           Decimal  @db.Decimal(10, 2)
  pernocta        Boolean  @default(false) // tarifa de pernoctación: el corte sigue la hora de corte de la sucursal (no la duración)
  special         Boolean  @default(false) // tarifa especial (promocional / negociada)
  status          String   @default("active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  branch   Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  roomType RoomType @relation(fields: [roomTypeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  stays    Stay[]

  @@unique([branchId, roomTypeId, durationMinutes])
  @@index([branchId])
  @@index([roomTypeId])
}

/// Tarifa personalizada: override por tier y/o vigencia para un tipo y duración.
model CustomRate {
  id              String    @id @default(uuid())
  branchId        String
  roomTypeId      String
  tierId          String?
  label           String
  durationMinutes Int
  price           Decimal   @db.Decimal(10, 2)
  validFrom       DateTime?
  validTo         DateTime?
  status          String    @default("active")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  branch   Branch      @relation(fields: [branchId], references: [id], onDelete: Cascade)
  roomType RoomType    @relation(fields: [roomTypeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tier     ClientTier? @relation(fields: [tierId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([branchId])
  @@index([roomTypeId])
  @@index([tierId])
}

// ─────────────────────────────────────────────────────────────────────────────
// FASE 2 — Catálogos (Tanda 2B)
// ─────────────────────────────────────────────────────────────────────────────

/// Área operativa / física (por sucursal). Usada por inventario y limpieza.
model Area {
  id            String   @id @default(uuid())
  branchId      String
  name          String
  description   String?
  type          String   @default("LIMPIEZA") // LIMPIEZA | RECEPCION | LAVANDERIA | ROPA | AMENITIES
  managesSubwarehouses Boolean @default(false)
  managesFloors Boolean  @default(false)
  warehouseId   String?
  status        String   @default("active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  branch        Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  warehouse     Warehouse?     @relation(fields: [warehouseId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subWarehouses SubWarehouse[]

  @@index([branchId])
  @@index([warehouseId])
}

/// FASE L6 — Subalmacén operativo dentro de un Área (ej. "Limpieza Torre B").
/// Tiene su propio stock y atiende un conjunto de habitaciones (cobertura).
/// coverageType: MANUAL | RANGE | ALL  (RANGE/MANUAL se resuelven al mismo set de habitaciones)
model SubWarehouse {
  id           String   @id @default(uuid())
  branchId     String
  areaId       String
  name         String
  coverageType String   @default("MANUAL")
  status       String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  area  Area               @relation(fields: [areaId], references: [id], onDelete: Cascade)
  rooms SubWarehouseRoom[]
  stock SubWarehouseStock[]

  @@index([branchId])
  @@index([areaId])
}

/// FASE L6c — Stock propio del subalmacén (lo que puede suministrar a sus habitaciones).
model SubWarehouseStock {
  id             String   @id @default(uuid())
  branchId       String
  subWarehouseId String
  articleKind    String   @default("LINEN_REUSABLE")
  name           String
  linenItemId    String?
  quantity       Int      @default(0)
  updatedAt      DateTime @updatedAt

  subWarehouse SubWarehouse @relation(fields: [subWarehouseId], references: [id], onDelete: Cascade)

  @@unique([subWarehouseId, articleKind, name])
  @@index([branchId])
  @@index([subWarehouseId])
}

/// FASE L6 — Cobertura: qué habitaciones atiende un subalmacén (set explícito).
model SubWarehouseRoom {
  id             String @id @default(uuid())
  branchId       String
  subWarehouseId String
  roomId         String

  subWarehouse SubWarehouse @relation(fields: [subWarehouseId], references: [id], onDelete: Cascade)
  room         Room         @relation(fields: [roomId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([subWarehouseId, roomId])
  @@index([subWarehouseId])
  @@index([roomId])
}

/// Categoría de inventario (por sucursal).
model InventoryCategory {
  id          String   @id @default(uuid())
  branchId    String
  name        String
  description String?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  branch   Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  products Product[]

  @@index([branchId])
}

/// Item configurable. `kind` clasifica su uso en el sistema.
model Item {
  id          String   @id @default(uuid())
  branchId    String
  kind        String // CHECKIN | RATE | SERVICE_PENALTY | MAINTENANCE | SERVICE
  subcategory String? // agrupación para Servicios y Penalidades
  name        String
  description String?
  price       Decimal? @db.Decimal(10, 2)
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([branchId])
  @@index([kind])
}

/// Horario / turno (por sucursal). daysOfWeek como CSV "1,2,3" (1=lunes…7=domingo).
model Schedule {
  id         String   @id @default(uuid())
  branchId   String
  name       String
  startTime  String // "HH:mm"
  endTime    String // "HH:mm"
  daysOfWeek String   @default("") // CSV de días
  status     String   @default("active")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([branchId])
}

// ─────────────────────────────────────────────────────────────────────────────
// FASE 3 — Operaciones: Habitaciones y Estancias (Tanda 3A)
// ─────────────────────────────────────────────────────────────────────────────

/// Habitación física. Estado conduce el mapa en tiempo real.
model Room {
  id         String   @id @default(uuid())
  branchId   String
  roomTypeId String
  number     String
  floor      String?
  // Estados RIZZOS: DISPONIBLE | RESERVADA | OCUPADA | LIMPIEZA_SOLICITADA |
  // LIMPIEZA_EN_ESPERA | LIMPIEZA_EN_CURSO | REQUIERE_REPASO | MANTENIMIENTO
  // (se mantienen FREE/OCCUPIED/CLEANING/MAINTENANCE por compatibilidad)
  status     String   @default("FREE")
  blocked    Boolean  @default(false) // habitación crítica bloqueada hasta resolver mantenimiento
  notes      String?
  tower      String? // Torre/Bloque (para agrupar la cobertura de subalmacenes)
  imageUrl        String?  @db.NVarChar(Max)
  frigobarEnabled Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  branch   Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  roomType RoomType @relation(fields: [roomTypeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  stays    Stay[]
  reservations      Reservation[]
  observations      Observation[]
  conciergeRequests ConciergeRequest[]
  inventory         RoomInventory[]
  invMovements      RoomInventoryMovement[]
  subWarehouseRooms SubWarehouseRoom[]

  @@unique([branchId, number])
  @@index([branchId])
  @@index([roomTypeId])
  @@index([status])
}

/// FASE L1 — Dotación BASE por tipo de habitación: el estándar de ropa/amenities/
/// productos/activos que cada habitación de ese tipo debe tener. Sirve para sugerir
/// carga inicial, reposición y comparar stock esperado vs actual.
/// articleKind: LINEN_REUSABLE | AMENITY | SALE | ASSET
model RoomTypeDotacion {
  id          String   @id @default(uuid())
  branchId    String
  roomTypeId  String
  category    String? // categoría (texto): "Ropa", "Amenities", etc.
  articleKind String   @default("LINEN_REUSABLE")
  name        String // artículo: "Sábana", "Jabón Premium"…
  linenItemId String? // vínculo opcional a un LinenItem (ropa/amenity existente)
  productId   String? // vínculo opcional a un Product (producto de venta/amenity)
  baseQty     Int      @default(1)
  required    Boolean  @default(false) // obligatorio para dejar la habitación disponible
  allowExtra  Boolean  @default(false) // permite cantidad adicional
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  branch   Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  roomType RoomType @relation(fields: [roomTypeId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([branchId])
  @@index([roomTypeId])
}

/// FASE L1 — La habitación como almacén virtual: stock por habitación × artículo.
/// La unicidad por nombre+tipo evita duplicar el mismo artículo en una habitación.
model RoomInventory {
  id          String   @id @default(uuid())
  branchId    String
  roomId      String
  articleKind String   @default("LINEN_REUSABLE")
  name        String
  linenItemId String?
  productId   String?
  quantity    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  room   Room   @relation(fields: [roomId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([roomId, articleKind, name])
  @@index([branchId])
  @@index([roomId])
}

/// FASE L1 — Kardex del inventario por habitación (movimientos). type incluye:
/// INITIAL | ROOM_LOAD | TRANSFER | LIMPIEZA_RETIRO | LIMPIEZA_REPO | LAUNDRY_OUT |
/// LAUNDRY_IN | ADJUST_POS | ADJUST_NEG | DAMAGED | LOST | AMENITY_CONSUMO | EXTRA | RETURN
model RoomInventoryMovement {
  id            String   @id @default(uuid())
  branchId      String
  roomId        String?
  type          String
  articleKind   String   @default("LINEN_REUSABLE")
  name          String
  quantity      Int // positivo entra a la habitación, negativo sale
  fromLocation  String? // origen (almacén/área) en texto
  toLocation    String? // destino en texto
  reference     String?
  note          String?
  createdByUserId String?
  createdAt     DateTime @default(now())

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  room   Room?  @relation(fields: [roomId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([branchId])
  @@index([roomId])
  @@index([type])
}

/// FASE L4 — Stock de ubicaciones no-habitación del ciclo de ropa.
/// location: DIRTY (Ropa Sucia Pendiente) | LAUNDRY (Lavandería) | CLEAN_CENTRAL (Ropa Limpia Central)
model LinenLocationStock {
  id          String   @id @default(uuid())
  branchId    String
  location    String
  articleKind String   @default("LINEN_REUSABLE")
  name        String
  linenItemId String? // vínculo al ítem de ropa legado, para re-acreditar el central
  quantity    Int      @default(0)
  updatedAt   DateTime @updatedAt

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, location, articleKind, name])
  @@index([branchId])
  @@index([location])
}

/// Estancia: ocupación de una habitación por un huésped, con tarifa congelada.
model Stay {
  id                String    @id @default(uuid())
  branchId          String
  roomId            String
  guestId           String
  rateId            String?
  tierId            String?
  status            String    @default("OPEN") // OPEN | CLOSED | CANCELLED
  checkInAt         DateTime  @default(now())
  plannedCheckoutAt DateTime
  checkOutAt        DateTime?
  durationMinutes   Int
  priceAgreed       Decimal   @db.Decimal(10, 2)
  adults            Int       @default(1)
  children          Int       @default(0)
  vehiclePlate      String? // placa del vehículo (búsqueda por placa)
  balanceDue        Decimal?  @db.Decimal(10, 2) // adeudo / saldo pendiente
  notes             String?
  renewedAt         DateTime? // última renovación (OCUPADA - RENOVADA)
  renewalCount      Int       @default(0)
  cleaningRequested Boolean   @default(false) // limpieza de renovación pendiente (no libera la habitación)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  branch           Branch      @relation(fields: [branchId], references: [id], onDelete: Cascade)
  room             Room        @relation(fields: [roomId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  guest            Guest       @relation(fields: [guestId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  rate             Rate?       @relation(fields: [rateId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tier             ClientTier? @relation(fields: [tierId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  additionalGuests StayGuest[]

  @@index([branchId])
  @@index([roomId])
  @@index([guestId])
  @@index([status])
}

/// Huéspedes adicionales de una estancia.
model StayGuest {
  id      String @id @default(uuid())
  stayId  String
  guestId String

  stay  Stay  @relation(fields: [stayId], references: [id], onDelete: Cascade)
  guest Guest @relation(fields: [guestId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([stayId, guestId])
  @@index([stayId])
  @@index([guestId])
}

// ─────────────────────────────────────────────────────────────────────────────
// FASE 3 — Operaciones (Tanda 3B): Reservas, Observaciones, Conserjería
// ─────────────────────────────────────────────────────────────────────────────

/// Reserva por tipo de habitación (opcionalmente una habitación concreta).
model Reservation {
  id                String   @id @default(uuid())
  branchId          String
  roomTypeId        String
  roomId            String?
  guestId           String?
  guestName         String? // si no hay Guest registrado aún
  phone             String?
  expectedCheckInAt DateTime
  durationMinutes   Int      @default(1440)
  adults            Int      @default(1)
  children          Int      @default(0)
  status            String   @default("PENDING") // PENDING | CONFIRMED | CANCELLED | FULFILLED
  notes             String?
  createdByUserId   String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  branch   Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  roomType RoomType @relation(fields: [roomTypeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  room     Room?    @relation(fields: [roomId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  guest    Guest?   @relation(fields: [guestId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([branchId])
  @@index([status])
  @@index([roomTypeId])
}

/// Observación operativa (general o asociada a una habitación).
model Observation {
  id              String   @id @default(uuid())
  branchId        String
  roomId          String?
  title           String?
  body            String
  status          String   @default("OPEN") // OPEN | RESOLVED
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  room   Room?  @relation(fields: [roomId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([branchId])
  @@index([status])
}

/// Solicitud de conserjería.
model ConciergeRequest {
  id              String   @id @default(uuid())
  branchId        String
  roomId          String?
  guestName       String?
  category        String? // taxi | comida | despertador | otros
  description     String
  status          String   @default("PENDING") // PENDING | IN_PROGRESS | DONE | CANCELLED
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  room   Room?  @relation(fields: [roomId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([branchId])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────────────────────
// FASE 4 — Ventas, Pagos y Caja (Tanda 4A)
// ─────────────────────────────────────────────────────────────────────────────

/// Almacén. En FASE 4 se usa uno por defecto ("Productos"); FASE 6 amplía tipos.
model Warehouse {
  id        String   @id @default(uuid())
  branchId  String
  name      String
  type      String   @default("PRODUCTS") // PRODUCTS | CLOTHING | RECEPTION | CLEANING | LAUNDRY | AMENITIES
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  stock  Stock[]
  areas  Area[]

  @@index([branchId])
}

/// Producto vendible (por sucursal).
model Product {
  id         String   @id @default(uuid())
  branchId   String
  categoryId String?
  name         String
  sku          String?
  barcode      String? // código de barras (EAN-13, etc.)
  imageUrl     String?  @db.NVarChar(Max) // imagen del artículo (data URL o URL)
  brand        String? // marca
  reusable     Boolean  @default(false) // ¿es reutilizable?
  productType  String   @default("PRODUCTO") // PRODUCTO | SERVICIO | AMENITY | INSUMO
  unit         String   @default("NIU") // unidad SUNAT (NIU, ZZ, KGM, ...)
  igvType      String   @default("GRAVADO") // GRAVADO | EXONERADO | INAFECTO
  igvPercent   Decimal  @default(18) @db.Decimal(5, 2) // % de IGV
  taxable      Boolean  @default(true) // ¿es tributable?
  salePrice    Decimal  @db.Decimal(10, 2)
  cost         Decimal? @db.Decimal(10, 2)
  reorderPoint Int      @default(0) // stock mínimo en el almacén
  receptionReorderPoint Int @default(0) // stock mínimo en el almacén de recepción
  status       String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  branch   Branch             @relation(fields: [branchId], references: [id], onDelete: Cascade)
  category InventoryCategory? @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  stock    Stock[]

  @@index([branchId])
  @@index([categoryId])
}

/// Stock de un producto en un almacén.
model Stock {
  id          String   @id @default(uuid())
  productId   String
  warehouseId String
  quantity    Int      @default(0)
  updatedAt   DateTime @updatedAt

  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([productId, warehouseId])
  @@index([productId])
  @@index([warehouseId])
}

/// Turno de caja. Las ventas/pagos se ligan al turno abierto.
model CashSession {
  id             String    @id @default(uuid())
  branchId       String
  openedByUserId String
  status         String    @default("OPEN") // OPEN | CLOSED
  openingAmount  Decimal   @db.Decimal(10, 2)
  closingAmount  Decimal?  @db.Decimal(10, 2)
  expectedAmount Decimal?  @db.Decimal(10, 2)
  notes          String?
  openedAt       DateTime  @default(now())
  closedAt       DateTime?

  branch    Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  sales     Sale[]
  movements CashMovement[]

  @@index([branchId])
  @@index([status])
}

/// Movimiento manual de caja (ingreso/egreso en efectivo) dentro de un turno.
model CashMovement {
  id              String   @id @default(uuid())
  cashSessionId   String
  branchId        String
  type            String // IN | OUT
  amount          Decimal  @db.Decimal(10, 2)
  concept         String
  createdByUserId String?
  createdAt       DateTime @default(now())

  session CashSession @relation(fields: [cashSessionId], references: [id], onDelete: Cascade)

  @@index([cashSessionId])
  @@index([branchId])
}

// ─────────────────────────────────────────────────────────────────────────────
// FASE 5 — Comprobantes electrónicos y Notas (Tanda 5A)
// ─────────────────────────────────────────────────────────────────────────────

/// Serie de folios (Folios Maestros): correlativo por sucursal y tipo de documento.
model FolioSeries {
  id            String   @id @default(uuid())
  branchId      String
  documentType  String // BOLETA | FACTURA | NOTE
  series        String // "B001", "F001", "NC01"
  currentNumber Int      @default(0)
  status        String   @default("active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, documentType, series])
  @@index([branchId])
}

/// Comprobante electrónico (Boleta/Factura) emitido a partir de una venta.
model Invoice {
  id             String   @id @default(uuid())
  branchId       String
  saleId         String?
  type           String // BOLETA | FACTURA
  series         String
  number         Int
  customerDoc    String?
  customerName   String
  subtotal       Decimal  @db.Decimal(10, 2) // base imponible
  taxAmount      Decimal  @db.Decimal(10, 2) // IGV
  total          Decimal  @db.Decimal(10, 2)
  status         String   @default("ISSUED") // ISSUED | VOIDED
  providerStatus String? // estado del PSE (mock)
  providerRef    String? // referencia del PSE (mock)
  issuedAt       DateTime @default(now())
  createdByUserId String?

  branch Branch            @relation(fields: [branchId], references: [id], onDelete: Cascade)
  notes  CreditDebitNote[]

  @@unique([branchId, series, number])
  @@index([branchId])
  @@index([status])
  @@index([type])
}

/// Nota de Crédito/Débito sobre un comprobante.
model CreditDebitNote {
  id              String   @id @default(uuid())
  branchId        String
  invoiceId       String
  type            String // CREDIT | DEBIT
  series          String
  number          Int
  reason          String
  total           Decimal  @db.Decimal(10, 2)
  status          String   @default("ISSUED")
  issuedAt        DateTime @default(now())
  createdByUserId String?

  branch  Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([branchId, series, number])
  @@index([branchId])
  @@index([invoiceId])
}

// ─────────────────────────────────────────────────────────────────────────────
// FASE 6 — Inventario / Kardex (Tanda 6A)
// ─────────────────────────────────────────────────────────────────────────────

/// Movimiento de inventario (Kardex). quantity es signed (− para salidas).
model InventoryMovement {
  id                String   @id @default(uuid())
  branchId          String
  productId         String
  warehouseId       String
  type              String // IN | OUT | ADJUST | SALE | TRANSFER | PURCHASE
  quantity          Int
  unitCost          Decimal? @db.Decimal(10, 2)
  reference         String?
  relatedWarehouseId String?
  createdByUserId   String?
  createdAt         DateTime @default(now())

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([branchId])
  @@index([productId])
  @@index([warehouseId])
  @@index([type])
}

// ─────────────────────────────────────────────────────────────────────────────
// FASE 6 — Logística (Tanda 6B)
// ─────────────────────────────────────────────────────────────────────────────

/// Proveedor (por sucursal).
model Supplier {
  id        String   @id @default(uuid())
  branchId  String
  name      String
  taxId     String?
  contact   String?
  phone     String?
  email     String?
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch    Branch            @relation(fields: [branchId], references: [id], onDelete: Cascade)
  purchases PurchaseInvoice[]

  @@index([branchId])
}

/// Ingreso con factura (compra): suma stock y actualiza el costo de los productos.
model PurchaseInvoice {
  id              String   @id @default(uuid())
  branchId        String
  supplierId      String
  warehouseId     String
  documentNumber  String? // nro de factura del proveedor
  total           Decimal  @db.Decimal(10, 2)
  status          String   @default("RECEIVED") // RECEIVED | CANCELLED
  notes           String?
  createdByUserId String?
  createdAt       DateTime @default(now())

  branch   Branch                @relation(fields: [branchId], references: [id], onDelete: Cascade)
  supplier Supplier              @relation(fields: [supplierId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  items    PurchaseInvoiceItem[]

  @@index([branchId])
  @@index([supplierId])
}

/// Línea de un ingreso con factura.
model PurchaseInvoiceItem {
  id         String  @id @default(uuid())
  purchaseId String
  productId  String
  quantity   Int
  unitCost   Decimal @db.Decimal(10, 2)
  subtotal   Decimal @db.Decimal(10, 2)

  purchase PurchaseInvoice @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  @@index([purchaseId])
}

// ─────────────────────────────────────────────────────────────────────────────
// FASE 7 — Limpieza (Tanda 7A)
// ─────────────────────────────────────────────────────────────────────────────

/// Ítem de checklist de inspección (plantilla por sucursal).
model ChecklistItem {
  id        String   @id @default(uuid())
  branchId  String
  name      String
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([branchId])
}

/// Tarea de limpieza de una habitación.
model HousekeepingTask {
  id                String    @id @default(uuid())
  branchId          String
  roomId            String
  assignedToUserId  String?
  status            String    @default("PENDING") // PENDING | IN_PROGRESS | DONE | INSPECTED
  result            String    @default("PENDING") // PENDING | APPROVED | REJECTED
  notes             String?
  completedAt       DateTime?
  inspectedAt       DateTime?
  inspectedByUserId String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  branch      Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  inspections TaskInspection[]
  linenInspections LinenInspection[]

  @@index([branchId])
  @@index([roomId])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────────────────────
// FASE 8 — RRHH (Tanda 8A)
// ─────────────────────────────────────────────────────────────────────────────

/// Marca de asistencia (entrada/salida), manual o por biometría.
model Attendance {
  id       String   @id @default(uuid())
  branchId String
  userId   String
  type     String // IN | OUT
  source   String   @default("MANUAL") // MANUAL | BIOMETRIC
  at       DateTime @default(now())
  note     String?
  deviceId String?

  @@index([branchId])
  @@index([userId])
  @@index([at])
}

/// Registro de auditoría de operaciones.
model ActivityLog {
  id        String   @id @default(uuid())
  branchId  String?
  userId    String?
  userEmail String?
  action    String // POST | PUT | PATCH | DELETE
  module    String
  entityId  String?
  summary   String
  createdAt DateTime @default(now())

  @@index([branchId])
  @@index([userId])
  @@index([createdAt])
}

/// Resultado de un ítem de checklist en una inspección de tarea.
model TaskInspection {
  id              String  @id @default(uuid())
  taskId          String
  checklistItemId String
  passed          Boolean
  note            String?

  task HousekeepingTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

// ─────────────────────────────────────────────────────────────────────────────
// FASE 7 — Mantenimiento y Lavandería (Tanda 7B)
// ─────────────────────────────────────────────────────────────────────────────

/// Mantenimiento (puede asociarse a una habitación).
model Maintenance {
  id               String    @id @default(uuid())
  branchId         String
  roomId           String?
  title            String
  description      String?
  status           String    @default("OPEN") // OPEN | IN_PROGRESS | DONE | CANCELLED
  cost             Decimal?  @db.Decimal(10, 2)
  assignedToUserId String?
  scheduledAt      DateTime?
  completedAt      DateTime?
  createdByUserId  String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([branchId])
  @@index([status])
}

/// Revisión de habitación.
model Revision {
  id              String   @id @default(uuid())
  branchId        String
  roomId          String
  notes           String?
  photo           String?  @db.NVarChar(Max) // foto adjunta (data URL base64) de la revisión
  status          String   @default("PENDING") // PENDING | OK | ISSUE
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([branchId])
  @@index([roomId])
}

/// Máquina de lavandería.
model LaundryMachine {
  id        String   @id @default(uuid())
  branchId  String
  name      String
  capacity  String?
  status    String   @default("available") // available | busy | maintenance
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([branchId])
}

// ─────────────────────────────────────────────────────────────────────────────
// FASE 8 — Biometría ZKTeco (Tanda 8B)
// ─────────────────────────────────────────────────────────────────────────────

/// Lector de huella ZKTeco (equipo de red, TCP puerto 4370).
model BiometricDevice {
  id         String    @id @default(uuid())
  branchId   String
  name       String
  ip         String
  port       Int       @default(4370)
  status     String    @default("offline") // offline | online | error
  lastSyncAt DateTime?
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  branch      Branch             @relation(fields: [branchId], references: [id], onDelete: Cascade)
  enrollments DeviceEnrollment[]

  @@index([branchId])
}

// ─────────────────────────────────────────────────────────────────────────────
// FASE 9 — WhatsApp (Tanda 9A)
// ─────────────────────────────────────────────────────────────────────────────

/// Instancia/conexión de WhatsApp.
model WhatsAppInstance {
  id          String   @id @default(uuid())
  branchId    String
  name        String
  provider    String   @default("mock") // mock | cloud | twilio
  phoneNumber String?
  status      String   @default("disconnected") // disconnected | connected
  config      String? // credenciales/config (JSON serializado)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([branchId])
}

/// Plantilla de mensaje con variables tipo {cliente}, {habitacion}, etc.
model MessageTemplate {
  id        String   @id @default(uuid())
  branchId  String
  name      String
  body      String
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([branchId])
}

/// Registro de mensajes enviados (renderizados).
model MessageLog {
  id         String   @id @default(uuid())
  branchId   String
  templateId String?
  to         String
  body       String
  status     String   @default("SENT") // SENT | FAILED
  createdAt  DateTime @default(now())

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([branchId])
}

/// Recordatorio: plantilla + disparador.
model Reminder {
  id         String   @id @default(uuid())
  branchId   String
  name       String
  templateId String?
  trigger    String? // texto libre del disparador (ej. "1h antes del checkout")
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([branchId])
}

/// Enrolamiento: mapea el usuario del huellero (deviceUserId) con un User.
model DeviceEnrollment {
  id           String   @id @default(uuid())
  deviceId     String
  userId       String
  deviceUserId String
  name         String?
  createdAt    DateTime @default(now())

  device BiometricDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@unique([deviceId, deviceUserId])
  @@index([deviceId])
  @@index([userId])
}

/// Carga de lavandería.
model LaundryTask {
  id              String    @id @default(uuid())
  branchId        String
  machineId       String?
  description     String
  status          String    @default("PENDING") // PENDING | WASHING | DONE
  createdByUserId String?
  createdAt       DateTime  @default(now())
  completedAt     DateTime?

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([branchId])
  @@index([status])
}

/// Venta a una estancia o a un cliente externo.
model Sale {
  id              String   @id @default(uuid())
  branchId        String
  stayId          String?
  guestId         String?
  customerName    String?
  cashSessionId   String?
  total           Decimal  @db.Decimal(10, 2)
  status          String   @default("OPEN") // OPEN | PAID | CANCELLED
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  branch      Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  cashSession CashSession? @relation(fields: [cashSessionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  items       SaleItem[]
  payments    Payment[]

  @@index([branchId])
  @@index([cashSessionId])
  @@index([status])
}

/// Línea de venta (snapshot del producto/servicio).
model SaleItem {
  id          String  @id @default(uuid())
  saleId      String
  productId   String?
  itemId      String?
  description String
  quantity    Int
  unitPrice   Decimal  @db.Decimal(10, 2)
  unitCost    Decimal? @db.Decimal(10, 2)
  subtotal    Decimal  @db.Decimal(10, 2)

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
}

/// Pago de una venta (pueden ser múltiples por venta).
model Payment {
  id              String   @id @default(uuid())
  branchId        String
  saleId          String
  cashSessionId   String?
  method          String // CASH | CARD | TRANSFER | WALLET
  amount          Decimal  @db.Decimal(10, 2)
  reference       String?
  createdByUserId String?
  createdAt       DateTime @default(now())

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@index([cashSessionId])
  @@index([branchId])
}

/// Pool de credenciales WiFi que recepción entrega a los huéspedes.
model WifiCredential {
  id        String   @id @default(uuid())
  branchId  String
  ssid      String
  password  String
  voucher   String?
  note      String?
  status    String   @default("active") // active | inactive
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([branchId])
}

// ─────────────────────────────────────────────────────────────────────────────
// RIZZOS — FASE R1: ropa/limpieza, turnos, servicios, inventario recepción
// ─────────────────────────────────────────────────────────────────────────────

/// Catálogo de ropa/amenities de limpieza (toallas, sábanas, edredones, amenities) con variante.
model LinenItem {
  id        String   @id @default(uuid())
  branchId  String
  type      String // TOALLA | SABANA | EDREDON | AMENITY
  name      String // p.ej. "VERDE MARGARITA", "INCAICA ROJA"
  color     String?
  reusable  Boolean  @default(true) // edredones van a lavandería pero NO se reponen automáticamente
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch      Branch            @relation(fields: [branchId], references: [id], onDelete: Cascade)
  stocks      LinenStock[]
  movements   LinenMovement[]
  inspections LinenInspection[]

  @@index([branchId])
  @@index([type])
}

/// Stock de ropa por piso, con remanente (REM) y suministrado (SUM).
model LinenStock {
  id          String   @id @default(uuid())
  branchId    String
  linenItemId String
  floor       String // "1","2","3" o "SIN PISO" para áreas
  rem         Int      @default(0)
  sum         Int      @default(0)
  updatedAt   DateTime @updatedAt

  branch    Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  linenItem LinenItem @relation(fields: [linenItemId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([linenItemId, floor])
  @@index([branchId])
}

/// Movimientos de ropa: transferencia (admin→piso), suministro, lavandería, recojo, ajuste.
model LinenMovement {
  id              String   @id @default(uuid())
  branchId        String
  linenItemId     String
  type            String // TRANSFER | SUPPLY | LAUNDRY | PICKUP | ADJUST
  quantity        Int // con signo
  floor           String?
  roomId          String?
  areaFrom        String?
  areaTo          String?
  reference       String?
  createdByUserId String?
  createdAt       DateTime @default(now())

  branch    Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  linenItem LinenItem @relation(fields: [linenItemId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([branchId])
  @@index([linenItemId])
}

/// Turno del personal de limpieza (con reglas de cierre).
model CleaningShift {
  id          String    @id @default(uuid())
  branchId    String
  userId      String
  shiftType   String // MANANA | TARDE
  status      String    @default("OPEN") // OPEN | CLOSED
  laundrySent Boolean   @default(false)
  openedAt    DateTime  @default(now())
  closedAt    DateTime?

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([branchId])
  @@index([userId])
}

/// Inspección de prendas dentro de una tarea de limpieza (recoger ropa/amenities).
model LinenInspection {
  id          String  @id @default(uuid())
  taskId      String
  linenItemId String?
  description String // nombre del item mostrado
  state       String  @default("OK") // OK | ROBADA | DETERIORADA
  pickup      Boolean @default(false)
  note        String?

  task      HousekeepingTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  linenItem LinenItem?       @relation(fields: [linenItemId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([taskId])
}

/// Suministro pendiente de entrega a una habitación (servicios y penalidades).
model RoomSupply {
  id              String    @id @default(uuid())
  branchId        String
  roomId          String
  stayId          String?
  description     String
  quantity        Int       @default(1)
  status          String    @default("PENDING") // PENDING | DELIVERED
  createdByUserId String?
  createdAt       DateTime  @default(now())
  deliveredAt     DateTime?

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([branchId])
  @@index([roomId])
  @@index([status])
}

/// Solicitud de productos de Recepción al Almacén (admin).
model ProductRequest {
  id              String   @id @default(uuid())
  branchId        String
  status          String   @default("REQUESTED") // REQUESTED | SENT | RECEIVED
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  branch Branch               @relation(fields: [branchId], references: [id], onDelete: Cascade)
  items  ProductRequestItem[]

  @@index([branchId])
  @@index([status])
}

model ProductRequestItem {
  id        String @id @default(uuid())
  requestId String
  productId String
  quantity  Int

  request ProductRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
}

/// Baja de stock de recepción (dar de baja).
model StockWriteOff {
  id              String   @id @default(uuid())
  branchId        String
  productId       String
  quantity        Int
  reason          String
  createdByUserId String?
  createdAt       DateTime @default(now())

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([branchId])
}

/// Cola de impresión (despachos/tickets).
model PrintJob {
  id        String   @id @default(uuid())
  branchId  String
  type      String // DESPACHO | TICKET | RECEPCION
  title     String
  payload   String? // JSON serializado
  status    String   @default("PENDING") // PENDING | PRINTED
  createdAt DateTime @default(now())

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([branchId])
  @@index([status])
}
