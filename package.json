{
  "name": "hotelsuite",
  "version": "0.0.0",
  "private": true,
  "description": "Sistema de gestión hotelera multi-sucursal",
  "workspaces": ["backend", "frontend"],
  "scripts": {
    "dev:backend": "npm run dev -w backend",
    "dev:frontend": "npm start -w frontend",
    "build": "npm run build -w backend && npm run build -w frontend",
    "lint": "npm run lint -w backend && npm run lint -w frontend",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.4.0",
    "@commitlint/config-conventional": "^19.4.0",
    "husky": "^9.1.5"
  }
}
